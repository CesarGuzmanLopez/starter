# Neovim Config Environment Variables
# Copy this to .env and fill in your values

# Minuet AI completion (se usa CESAR_PROXY_KEY del proxy, o setear esta)
MINUET_API_KEY=your-api-key-here

# Proxy Cesar (API key para servidor LLM propio)
CESAR_PROXY_KEY=your-api-key-here
CESAR_LLM_URL=https://your-llm-server.com/v1  # URL completa, minuet la usa directo

# Optional: Java JDK path (auto-detected if not set)
# JAVA_HOME=/usr/lib/jvm/java-22-openjdk
